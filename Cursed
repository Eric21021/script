-- MODIFIED setLagger (now calls actual lagger logic)
local function setLagger(state)
	laggerEnabled = state
	local tw = TweenInfo.new(0.15)
	if laggerEnabled then
		TweenService:Create(ToggleBg, tw, {BackgroundColor3 = Color3.fromRGB(220, 50, 50)}):Play()
		TweenService:Create(ToggleDot, tw, {Position = UDim2.new(0, 21, 0.5, -7)}):Play()
		startLagger()
	else
		TweenService:Create(ToggleBg, tw, {BackgroundColor3 = Color3.fromRGB(65, 65, 65)}):Play()
		TweenService:Create(ToggleDot, tw, {Position = UDim2.new(0, 3, 0.5, -7)}):Play()
		stopLaggerLoop()
	end
end

