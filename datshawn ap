    Row.BackgroundColor3 = Color3.fromRGB(35,35,35); Row.ZIndex = 11
    Instance.new("UICorner", Row).CornerRadius = UDim.new(0,16)

    local Avatar = Instance.new("ImageLabel", Row)
    Avatar.Size = UDim2.new(0,32,0,32); Avatar.Position = UDim2.new(0,8,0.5,-16)
    Avatar.BackgroundTransparency = 1; Avatar.ZIndex = 12
    pcall(function() Avatar.Image = Players:GetUserThumbnailAsync(plr.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size48x48) end)
    Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1,0)

