    NH.Size = UDim2.new(0.34,0,1,0); NH.Position = UDim2.new(0,48,0,0)
    NH.BackgroundTransparency = 1; NH.ZIndex = 12

    local DN = Instance.new("TextLabel", NH)
    DN.Size = UDim2.new(1,0,0.5,0); DN.BackgroundTransparency = 1
    DN.Text = plr.DisplayName; DN.Font = Enum.Font.FredokaOne; DN.TextScaled = true
    DN.TextXAlignment = Enum.TextXAlignment.Left; DN.TextColor3 = Color3.fromRGB(240,240,240)
    DN.TextTruncate = Enum.TextTruncate.AtEnd; DN.ZIndex = 13

    local UN = Instance.new("TextLabel", NH)
    UN.Size = UDim2.new(1,0,0.5,0); UN.Position = UDim2.new(0,0,0.5,0)
    UN.BackgroundTransparency = 1; UN.Text = "(@"..plr.Name..")"
    UN.Font = Enum.Font.Gotham; UN.TextScaled = true
    UN.TextXAlignment = Enum.TextXAlignment.Left; UN.TextColor3 = Color3.fromRGB(180,180,180)
    UN.TextTruncate = Enum.TextTruncate.AtEnd; UN.ZIndex = 13

    local function makeBtn(txt, pos)
        local B = Instance.new("TextButton", Row)
        B.Size = UDim2.new(0.24,0,0.65,0); B.Position = pos
        B.Font = Enum.Font.FredokaOne; B.TextScaled = true
        B.TextColor3 = Color3.fromRGB(255,255,255)
        B.BackgroundColor3 = Color3.fromRGB(60,60,60)
        B.ZIndex = 14; B.Text = txt
        Instance.new("UICorner", B); return B
    end

    local SemiBtn = makeBtn("SEMI", UDim2.new(0.50,0,0.18,0))
    local FullBtn = makeBtn("FULL", UDim2.new(0.76,0,0.18,0))

    SemiBtn.MouseButton1Click:Connect(function() runSemi(plr) end)
    FullBtn.MouseButton1Click:Connect(function() runFull(plr) end)
end

