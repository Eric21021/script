local function cap(s) return s:sub(1,1):upper()..s:sub(2):lower() end

local function createToggle(name, parent, tbl, key)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1,0,0,26); btn.Text = cap(name)
    btn.Font = Enum.Font.FredokaOne; btn.TextSize = 13
    btn.TextColor3 = Color3.fromRGB(255,255,255); btn.ZIndex = 25
    btn.BackgroundColor3 = tbl[key] and Color3.fromRGB(50,90,50) or Color3.fromRGB(55,55,55)
    btn.BackgroundTransparency = 0.1
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,7)
    local s = Instance.new("UIStroke", btn); s.Color = Color3.fromRGB(160,160,160); s.Thickness = 0.7
    btn.MouseButton1Click:Connect(function()
        tbl[key] = not tbl[key]
        btn.BackgroundColor3 = tbl[key] and Color3.fromRGB(50,90,50) or Color3.fromRGB(55,55,55)
        saveSettings()
    end)
end

