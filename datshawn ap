local TweenService     = game:GetService("TweenService")
local HttpService      = game:GetService("HttpService")

--// SETTINGS
local SETTINGS_FILE = "DatShawnAPConfig.json"
local SelectedCommands = {
    Semi = {balloon=true, tiny=true,  rocket=true, inverse=true, ragdoll=false, jail=false, morph=false, jumpscare=false},
    Full = {balloon=true, tiny=false, rocket=true, inverse=true, ragdoll=true,  jail=true,  morph=true,  jumpscare=true},
}

local function saveSettings()
    if writefile then
        pcall(function() writefile(SETTINGS_FILE, HttpService:JSONEncode(SelectedCommands)) end)
    end
end

-- load saved settings
if isfile and isfile(SETTINGS_FILE) then
    local ok, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(SETTINGS_FILE))
    if ok and type(decoded) == "table" then
        for k, v in pairs(decoded) do SelectedCommands[k] = v end
    end
end

--// ADMIN CMD LOGIC
local commandCache, profileCache = {}, {}
local cmds = {"balloon","tiny","rocket","inverse","ragdoll","jail","morph","jumpscare"}

local function cacheActivated(obj)
    local cached = {}
    local ok, conns = pcall(getconnections, obj.Activated)
    if ok and type(conns) == "table" then
        for _, c in ipairs(conns) do
            if type(c.Function) == "function" then table.insert(cached, c.Function) end
        end
    end
    return cached
end

local function fireActivated(cached)
    for _, fn in ipairs(cached) do task.spawn(fn) end
end

local function getAdminFrames()
    local panel = adminPanel:FindFirstChild("AdminPanel")
    local content  = panel and panel:FindFirstChild("Content")
    local profiles = panel and panel:FindFirstChild("Profiles")
    if content and profiles then
        return content:FindFirstChild("ScrollingFrame"), profiles:FindFirstChild("ScrollingFrame")
    end
end

local function runCmd(cmd, target)
    if not target then return end
    local cFrame, pFrame = getAdminFrames()
    if not cFrame or not pFrame then return end
    local pBtn = pFrame:FindFirstChild(target.Name)
    local cBtn = cFrame:FindFirstChild(cmd)
    if not pBtn or not cBtn then return end
    if not profileCache[target.Name] then profileCache[target.Name] = cacheActivated(pBtn) end
    if not commandCache[cmd]         then commandCache[cmd]         = cacheActivated(cBtn) end
    fireActivated(profileCache[target.Name])
    task.wait()
    fireActivated(commandCache[cmd])
end

local function runSemi(plr)
    task.spawn(function()
        for _, cmd in ipairs(cmds) do
            if SelectedCommands.Semi[cmd] then runCmd(cmd, plr) end
        end
    end)
end

local function runFull(plr)
    task.spawn(function()
        for _, cmd in ipairs(cmds) do
            if SelectedCommands.Full[cmd] then runCmd(cmd, plr) end
        end
    end)
end

--// SNOW
local function applySnow(parent)
    task.spawn(function()
        while parent and parent.Parent do
            task.wait(0.12)
            local f = Instance.new("TextLabel")
            f.Size = UDim2.fromOffset(math.random(8,14), math.random(8,14))
            f.Position = UDim2.new(math.random(), 0, -0.05, 0)
            f.BackgroundTransparency = 1
            f.Text = "*"
            f.Font = Enum.Font.FredokaOne
            f.TextScaled = true
            f.TextColor3 = Color3.new(1,1,1)
            f.TextTransparency = 0.3
            f.ZIndex = parent.ZIndex + 1
            f.Parent = parent
            local dx = f.Position.X.Scale + (math.random(-15,15)/100)
            local t = TweenService:Create(f, TweenInfo.new(math.random(25,40)/10, Enum.EasingStyle.Linear),
                {Position=UDim2.new(dx,0,1.1,0), TextTransparency=0.8})
            t:Play()
            t.Completed:Connect(function() f:Destroy() end)
        end
    end)
end

